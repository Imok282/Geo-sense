# ── GeoSense Pro — Firebase Configuration ──────────────────────────────────
# Copy this file to .env and fill in your values from:
#   Firebase Console → Project Settings → Your Apps → SDK Setup & Config
#
# IMPORTANT: Never commit the real .env to git.
# ─────────────────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=geosense-pro-ai.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://geosense-pro-ai-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=geosense-pro-ai
VITE_FIREBASE_STORAGE_BUCKET=geosense-pro-ai.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id-here
VITE_FIREBASE_APP_ID=your-app-id-here

# ── ESP32 Firmware Auth ──────────────────────────────────────────────────────
# Firebase Console → Project Settings → Service Accounts → Database Secrets
# Used in the firmware as DB_SECRET (see geosense_water_node.ino)
#
# FIREBASE_DB_SECRET=your-legacy-database-secret-here
